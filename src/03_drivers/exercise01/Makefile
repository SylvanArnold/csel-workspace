EXE=app # Name of the executable to be generated
SRCS=$(wildcard *.c) # List of source files in the current directory

ifeq ($(target),) # Set target to nano if not defined
target=nano
endif

# Compiler flags for building the source files
# -Wall -Wextra      : Enable most compiler warnings
# -g                 : Include debug information for debugging
# -c                 : Compile only, do not link
# -O0                : No optimization (easier debugging)
# -MD                : Generate dependency files for make
# -std=gnu11         : Use GNU C11 standard
CFLAGS=-Wall -Wextra -g -c -O0 -MD -std=gnu11

TOOLCHAIN_PATH=/buildroot/output/host/usr/bin/ 
TOOLCHAIN=$(TOOLCHAIN_PATH)aarch64-linux- #Architecture prefix

# Architecture specific flags for the compiler
# -mcpu=cortex-a53   : Optimize for ARM Cortex-A53 CPU
# -funwind-tables    : Generate unwind tables for stack traces
CFLAGS+=-mcpu=cortex-a53 -funwind-tables
##CFLAGS+=-O2 -fno-omit-frame-pointer
OBJDIR=.obj/nano
EXEC=$(EXE)


CC=$(TOOLCHAIN)gcc # C compiler
LD=$(TOOLCHAIN)gcc # Linker (using gcc for linking)
AR=$(TOOLCHAIN)ar # Archiver for creating static libraries
STRIP=$(TOOLCHAIN)strip # Directory for object files based on the target

OBJDIR=.obj/$(target)
OBJS= $(addprefix $(OBJDIR)/, $(SRCS:.c=.o))

$(OBJDIR)/%o: %c
	$(CC) $(CFLAGS) $< -o $@

all: $(OBJDIR)/ $(EXEC)

# Link the object files to create the final executable
$(EXEC): $(OBJS) $(LINKER_SCRIPT)
	$(LD) $(OBJS) $(LDFLAGS) -o $@

# Rule to create the object directory if it doesn't exist
$(OBJDIR)/:
	mkdir -p $(OBJDIR)

# Clean rule to remove object files and the executable
clean:
	rm -Rf $(OBJDIR) $(EXEC) $(EXEC)_s *~

# Clean all rule to remove all generated files and directories
clean_all: clean
	rm -Rf .obj $(EXE) $(EXE)_s $(EXE)_a $(EXE)_a_s $(EXE)_h $(EXE)_h_s

# Include dependency files generated by the compiler
-include $(OBJS:.o=.d)

# Declare the phony targets to avoid conflicts with files of the same name
.PHONY: all clean clean_all
